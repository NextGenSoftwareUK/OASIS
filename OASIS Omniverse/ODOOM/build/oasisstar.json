{
  // OASIS STAR — full key reference: OASIS Omniverse/Docs/STAR_Games_User_Guide.md (Section 8).
  // Lines starting with // are comments. Do not put double-quoted key names inside comments.
  // star config save in-game may rewrite this file and drop comments; keep a backup if needed.

  // How the native client reaches STAR (e.g. remote HTTP).
  "star_transport": "remote",
  // WEB5 STAR API — quests, STAR inventory, progress. Local dev often port 8888.
  "star_api_url": "http://localhost:8888",
  // WEB4 OASIS API — login, avatar, token refresh. Local dev often port 7777.
  "oasis_api_url": "http://localhost:7777",
  // Optional path for OASIS DNA / tooling (see developer transport docs if used).
  "oasis_dna_path": "",

  // 1 = show beam-in / anorak-style face where supported; 0 = off.
  "beam_face": 1,
  // 1 = extra STAR logging when this file is loaded at startup.
  "star_debug": 1,
  // Quest cache after progress: client = merge in client; server or full = fuller server refresh (see developer quest guide).
  "quest_progress_refresh": "client",

  // stack_* : stored and shown in star config; main PostTouch path does not branch like OQuake. See user guide §8.5.
  "stack_armor": 1,
  "stack_weapons": 1,
  "stack_powerups": 1,
  "stack_keys": 1,

  // 1 = mint NFT when that category is collected. 0 = off.
  "mint_weapons": 1,
  "mint_armor": 1,
  "mint_powerups": 0,
  "mint_keys": 1,

  // NFT mint provider and optional wallet to receive minted NFTs.
  "nft_provider": "SolanaOASIS",
  "send_to_address_after_minting": "",

  // 1 = at max you can still pick up into STAR; 0 = vanilla leave on floor when full.
  "always_allow_pickup_if_max": 1,
  // 1 = also add STAR row when engine already consumed pickup; 0 = only when integration path adds.
  "always_add_items_to_inventory": 0,

  // Caps when using health/armor from STAR overlay (and related checks).
  "max_health": 200,
  "max_armor": 200,

  // 0 = below max, bank pickup in STAR (engine does not apply on touch). 1 = vanilla apply on pickup.
  "use_health_on_pickup": 0,
  "use_armor_on_pickup": 0,
  "use_powerup_on_pickup": 0,

