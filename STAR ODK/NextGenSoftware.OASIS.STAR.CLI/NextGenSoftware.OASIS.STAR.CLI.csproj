    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\CSharpDNATemplates\ZomeTemplate.tt" Link="DNATemplates\CSharpDNATemplates\ZomeTemplate.tt" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\CSharpDNATemplates\Interfaces\ICelestialBodyDNATemplate.cs" Link="DNATemplates\CSharpDNATemplates\Interfaces\ICelestialBodyDNATemplate.cs" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
