  <!-- Force-copy entire DNATemplates from STAR project into publish output (runs after publish so files are always there) -->
  <Target Name="CopyDNATemplatesToPublish" AfterTargets="Publish">
    <PropertyGroup>
      <_StarDnaTemplatesPath>$([MSBuild]::NormalizePath('$(MSBuildProjectDirectory)', '..', 'NextGenSoftware.OASIS.STAR', 'DNATemplates'))</_StarDnaTemplatesPath>
    </PropertyGroup>
    <ItemGroup>
      <_DnaTemplateFiles Include="$(_StarDnaTemplatesPath)\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_DnaTemplateFiles)" DestinationFolder="$(PublishDir)DNATemplates\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Copied DNATemplates to $(PublishDir)DNATemplates" />
  </Target>

</Project>
