    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\MetaDataDNATemplates\Types\DoubleDNA.cs" Link="DNATemplates\MetaDataDNATemplates\Types\DoubleDNA.cs" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
