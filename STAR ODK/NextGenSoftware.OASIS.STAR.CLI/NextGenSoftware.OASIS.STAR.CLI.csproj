    <None Include="installers\DNATemplates\CSharpDNATemplates\Interfaces\ICelestialBodyDNATemplate.cs" />
    <Compile Remove="installers\DNATemplates\CSharpDNATemplates\Interfaces\IHolonDNATemplate.cs" />
    <None Include="installers\DNATemplates\CSharpDNATemplates\Interfaces\IHolonDNATemplate.cs" />
    <Compile Remove="installers\DNATemplates\CSharpDNATemplates\Interfaces\ILoadHolonDNATemplate.cs" />
    <None Include="installers\DNATemplates\CSharpDNATemplates\Interfaces\ILoadHolonDNATemplate.cs" />
