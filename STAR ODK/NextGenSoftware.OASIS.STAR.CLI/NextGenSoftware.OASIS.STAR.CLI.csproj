<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>star</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NextGenSoftware.OASIS.STAR.CLI.Lib\NextGenSoftware.OASIS.STAR.CLI.Lib.csproj" />
    <ProjectReference Include="..\NextGenSoftware.OASIS.STAR\NextGenSoftware.OASIS.STAR.csproj" />
  </ItemGroup>

  <!-- DNA folder: JSON only (STARDNA.cs is chosen at build time in STAR.DNA project) -->
  <ItemGroup>
    <Content Include="..\NextGenSoftware.OASIS.STAR.STARDNA\DNA\**\*.json" LinkBase="DNA" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
  </ItemGroup>
  <!-- Exclude publish output from compilation: DNATemplates etc. are copied into publish/ and must not be compiled (they are templates with placeholders). -->
  <ItemGroup>
    <Compile Remove="publish\**\*.cs" />
  </ItemGroup>
  <!-- STAR DNATemplates (Rust, hApp, C#, etc.) — beside star output; excluded from single-file bundle -->
  <ItemGroup>
    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\**\*"
             LinkBase="DNATemplates"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest"
             Visible="false"
             ExcludeFromSingleFile="true" />
    <!-- C# template .cs files: listed manually so publish always copies them -->
    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\CSharpDNATemplates\CelestialBodyDNATemplate.cs" Link="DNATemplates\CSharpDNATemplates\CelestialBodyDNATemplate.cs" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\CSharpDNATemplates\HolonDNATemplate.cs" Link="DNATemplates\CSharpDNATemplates\HolonDNATemplate.cs" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
    <Content Include="..\NextGenSoftware.OASIS.STAR\DNATemplates\CSharpDNATemplates\LoadHolonDNATemplate.cs" Link="DNATemplates\CSharpDNATemplates\LoadHolonDNATemplate.cs" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Visible="false" ExcludeFromSingleFile="true" />
