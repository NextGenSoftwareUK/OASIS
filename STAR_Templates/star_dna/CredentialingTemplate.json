{
  "$schema": "https://oasisweb4.com/star-oapp-dna/v1",
  "OAPPId": "7ff4bfbf-299b-4032-aafe-0ad174a140ad",
  "OAPPName": "CredentialingTemplate",
  "OAPPDesc": "Holonic credentialing and reputation template. Profiles hold verifiable credentials endorsed by peers; all attestations are OASIS Holons; endorsements earn karma on the reputation layer.",
  "OAPPVersion": "1.0.0",
  "OAPPType_enum": 5,
  "OAPPType_name": "OAPPTemplate",
  "Author": "OASIS_ADMIN",
  "CreatedOn": "2026-03-26",
  "Licence": "MIT",
  "CelestialBodyDNA": {
    "Name": "CredentialingTemplatePlanet",
    "CelestialBodies": [
      {
        "Name": "CredentialingTemplatePlanet",
        "CelestialBodyType": "Planet",
        "Zomes": [
          {
            "Name": "IdentityZome",
            "Description": "Credentialing profiles linked to OASIS Avatars",
            "Holons": [
              {
                "Name": "ProfileHolon",
                "Description": "A credentialing profile holding credentials and endorsements",
                "Fields": [
                  { "Name": "ProfileId",       "Type": "Guid",     "Required": true },
                  { "Name": "AvatarId",        "Type": "Guid",     "Required": false },
                  { "Name": "DisplayName",     "Type": "string",   "Required": true },
                  { "Name": "Headline",        "Type": "string",   "Required": false },
                  { "Name": "Skills",          "Type": "string[]", "Required": false },
                  { "Name": "CredentialIds",   "Type": "Guid[]",   "Required": false },
                  { "Name": "EndorsementIds",  "Type": "Guid[]",   "Required": false },
                  { "Name": "CreatedAt",       "Type": "DateTime", "Required": false },
                  { "Name": "KarmaSynced",     "Type": "bool",     "Required": false }
                ]
              }
            ]
          },
          {
            "Name": "CredentialZome",
            "Description": "Verifiable credentials issued and attested on OASIS",
            "Holons": [
              {
                "Name": "CredentialHolon",
                "Description": "A verifiable credential held by a profile — attested on OASIS",
                "Fields": [
                  { "Name": "CredentialId",      "Type": "Guid",     "Required": true },
                  { "Name": "HolderAvatarId",    "Type": "Guid",     "Required": false },
                  { "Name": "IssuerAvatarId",    "Type": "Guid",     "Required": false },
                  { "Name": "IssuerName",        "Type": "string",   "Required": true },
                  { "Name": "CredentialType",    "Type": "string",   "Required": true,
                    "Enum": ["qualification", "certification", "achievement", "license", "badge"] },
                  { "Name": "Title",             "Type": "string",   "Required": true },
                  { "Name": "IssuedAt",          "Type": "DateTime", "Required": false },
                  { "Name": "ExpiresAt",         "Type": "DateTime", "Required": false },
                  { "Name": "VerificationHash",  "Type": "string",   "Required": false,
                    "Description": "SHA256 hash of the credential document for tamper-detection" },
                  { "Name": "KarmaSynced",       "Type": "bool",     "Required": false }
                ]
              }
            ]
          },
          {
            "Name": "VerificationZome",
            "Description": "Peer endorsements — both parties earn karma",
            "Holons": [
              {
                "Name": "EndorsementHolon",
                "Description": "A peer endorsement of a skill or credential",
                "Fields": [
                  { "Name": "EndorsementId",   "Type": "Guid",     "Required": true },
                  { "Name": "EndorserAvatarId","Type": "Guid",     "Required": false },
                  { "Name": "HolderAvatarId",  "Type": "Guid",     "Required": false },
                  { "Name": "EndorserName",    "Type": "string",   "Required": true },
                  { "Name": "Skill",           "Type": "string",   "Required": true },
                  { "Name": "Comment",         "Type": "string",   "Required": false },
                  { "Name": "CreatedAt",       "Type": "DateTime", "Required": false },
                  { "Name": "KarmaSynced",     "Type": "bool",     "Required": false }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
