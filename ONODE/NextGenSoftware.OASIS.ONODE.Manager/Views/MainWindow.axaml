<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NextGenSoftware.OASIS.ONODE.Manager.ViewModels"
        x:Class="NextGenSoftware.OASIS.ONODE.Manager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ONODE Manager"
        Width="900" Height="640"
        MinWidth="700" MinHeight="500"
        Background="#0D0D1A">

    <Window.Styles>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#AAAACC" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#00BFFF" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#1A2040" />
            <Setter Property="Foreground" Value="#00BFFF" />
            <Setter Property="BorderBrush" Value="#00BFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#1A0D0D" />
            <Setter Property="Foreground" Value="#FF6666" />
            <Setter Property="BorderBrush" Value="#FF4444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#0A0A18" Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Ellipse Width="16" Height="16" Fill="{Binding OverallStatusColour}" />
                    <TextBlock Text="ONODE Manager" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding OverallStatus}" Foreground="{Binding OverallStatusColour}" VerticalAlignment="Center" FontSize="13" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Peers:" Foreground="#666688" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AggregatePeers}" Foreground="#00BFFF" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="↑" Foreground="#666688" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding AggregateBytesOut}" Foreground="#00BFFF" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="↓" Foreground="#666688" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding AggregateBytesIn}" Foreground="#00BFFF" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Classes="action" Command="{Binding StartAllCommand}" Content="▶ Start All" Margin="4,0" />
                <Button Grid.Column="3" Classes="danger" Command="{Binding StopAllCommand}"  Content="■ Stop All"  Margin="4,0" />
                <Button Grid.Column="4" Classes="action" Command="{Binding RestartAllCommand}" Content="↺ Restart All" Margin="4,0" />
            </Grid>
        </Border>

        <!-- Main tabs -->
        <TabControl Background="Transparent">

            <!-- Dashboard -->
            <TabItem Header="Dashboard">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Services}" Margin="16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ServiceViewModel">
                                <Border Background="#12122A" BorderBrush="{Binding StatusColour}" BorderThickness="1"
                                        CornerRadius="6" Margin="8" Padding="14,10" Width="200">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Ellipse Width="10" Height="10" Fill="{Binding StatusColour}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Id}" FontSize="15" FontWeight="Bold" Foreground="White" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColour}" FontSize="12" />
                                        <TextBlock Text="{Binding Uptime, StringFormat='Uptime: {0}'}" Foreground="#888899" FontSize="11" />
                                        <TextBlock Text="{Binding Port, StringFormat='Port: {0}'}" Foreground="#888899" FontSize="11" />
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                            <Button Classes="action" Command="{Binding StartCommand}"   Content="▶" Padding="8,3" FontSize="11" IsEnabled="{Binding Installed}" />
                                            <Button Classes="danger" Command="{Binding StopCommand}"   Content="■" Padding="8,3" FontSize="11" />
                                            <Button Classes="action" Command="{Binding RestartCommand}" Content="↺" Padding="8,3" FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- Logs -->
            <TabItem Header="Logs">
                <Grid RowDefinitions="*,Auto" Margin="12">
                    <ScrollViewer Grid.Row="0">
                        <TextBlock Text="{Binding UnifiedLogs}"
                                   FontFamily="Consolas,Monospace"
                                   FontSize="11"
                                   Foreground="#AAAACC"
                                   TextWrapping="NoWrap"
                                   Margin="4" />
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Config -->
            <TabItem Header="Config (OASISDNA)">
                <Grid RowDefinitions="Auto,*,Auto" Margin="12" RowDefinitions="Auto,*,Auto">
                    <Button Grid.Row="0" Classes="action" Command="{Binding LoadConfigCommand}"
                            Content="Load OASISDNA.json" HorizontalAlignment="Left" Margin="0,0,0,8" />
                    <TextBox Grid.Row="1"
                             Text="{Binding ConfigJson}"
                             FontFamily="Consolas,Monospace"
                             FontSize="12"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             Background="#0A0A18"
                             Foreground="#AADDFF"
                             BorderBrush="#334"
                             Margin="0,0,0,8" />
                    <Button Grid.Row="2" Classes="action" Command="{Binding SaveConfigCommand}"
                            Content="Save OASISDNA.json" HorizontalAlignment="Left" />
                </Grid>
            </TabItem>

            <!-- Providers -->
            <TabItem Header="Providers">
                <Grid RowDefinitions="Auto,*" Margin="12">
                    <!-- Column header -->
                    <Grid Grid.Row="0" ColumnDefinitions="16,*,80,80,80,80" Margin="4,0,4,4">
                        <TextBlock Grid.Column="1" Text="Provider"       Foreground="#666688" FontSize="11" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="Status"         Foreground="#666688" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="Priority"       Foreground="#666688" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text=""               Foreground="#666688" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="Toggle"         Foreground="#666688" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" />
                    </Grid>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Providers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ProviderViewModel">
                                    <Border Background="#12122A" BorderBrush="#1E1E3A" BorderThickness="0,0,0,1" Padding="4,6">
                                        <Grid ColumnDefinitions="16,*,80,80,80,80">
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding DotColour}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding FriendlyName}" Foreground="White" FontSize="12" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{Binding DotColour}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{Binding Priority}" Foreground="#AAAACC" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                                                <Button Classes="action" Command="{Binding IncreasePriorityCommand}" Content="▲" Padding="4,2" FontSize="10" />
                                                <Button Classes="action" Command="{Binding DecreasePriorityCommand}" Content="▼" Padding="4,2" FontSize="10" />
                                            </StackPanel>
                                            <Button Grid.Column="5" Classes="action" Command="{Binding ToggleCommand}"
                                                    Content="{Binding StatusText}"
                                                    Padding="6,3" FontSize="11" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- About -->
            <TabItem Header="About">
                <StackPanel Margin="20" Spacing="8">
                    <TextBlock Text="ONODE Manager" FontSize="22" FontWeight="Bold" Foreground="#00BFFF" />
                    <TextBlock Text="{Binding Version, StringFormat='Version: {0}'}" Foreground="#AAAACC" />
                    <TextBlock Text="{Binding NodeId, StringFormat='Node ID: {0}'}" Foreground="#AAAACC" />
                    <TextBlock Text="Manages OASIS Web4–Web10 node services." Foreground="#888899" Margin="0,8,0,0" />
                    <TextBlock Text="© NextGen Software Ltd" Foreground="#555566" />
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
