{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "OASIS": {
    "UseTestDataWhenLiveDataNotAvailable": false
  },
  "A2A": {
    "Webhook": {
      "Enabled": true,
      "AllowHttp": false,
      "TimeoutSeconds": 5,
      "MaxRetries": 2
    }
  }
}





