PORT=3142
REFRESH_INTERVAL_SEC=90

# Absolute or relative to app/: default ../data/sites.json then ../data/sites.example.json
# SITES_JSON_PATH=../data/sites.json

# Pan Galactic Timebank — set this to enable live circle telemetry instead of mock data.
# Each site's pgtCircleIds array in sites.json maps to circles in the running Timebank.
# PGT_BASE_URL=http://localhost:3002
