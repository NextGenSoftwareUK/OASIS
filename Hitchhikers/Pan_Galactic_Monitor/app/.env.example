PORT=3142
REFRESH_INTERVAL_SEC=90

# Absolute or relative to app/: default ../data/sites.json then ../data/sites.example.json
# SITES_JSON_PATH=../data/sites.json

# Pan Galactic Timebank — set this to enable live circle telemetry instead of mock data.
# Each site's pgtCircleIds array in sites.json maps to circles in the running Timebank.
# PGT_BASE_URL=http://localhost:3002

# Pangea Launchboard — set both to pull cap table orgs as equity pins on the globe.
# PANGEA_API_URL is the base URL of the running Launchboard instance.
# PANGEA_MONITOR_API_KEY must match MONITOR_API_KEY set in Launchboard's environment.
# PANGEA_API_URL=http://localhost:3001
# PANGEA_MONITOR_API_KEY=your-secret-key-here

# ── OASIS / STAR integration ──────────────────────────────────────────────────
# Enable OASIS Avatar lookup and karma sync for pledge, exchange, guide and
# builder pins. Set OASIS_ENABLED=true and point to a running OASIS WebAPI.
#
# OAPP ID: b0bf0be6-4462-46da-a910-03d0081b48b3 (PanGalacticMonitor, OAPPTemplate)
#
# OASIS_ENABLED=true
# OASIS_API_URL=http://localhost:5001
# OASIS_USERNAME=OASIS_ADMIN
# OASIS_PASSWORD=your-oasis-password
# OASIS_JWT=                          # optional: bypass auto-auth with a pre-existing JWT
