<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <PackageId>NextGenSoftware.OASIS.Web8.Core</PackageId>
    <Company>NextGen Software Ltd</Company>
    <Product>WEB8 OASIS Inter-Galactic Layer Core</Product>
    <Title>WEB8 OASIS Inter-Galactic Layer Core</Title>
    <Summary>The Core (Business Logic Layer) for WEB8 - the fractal holonic mesh-networking layer. Hosts the GalacticMeshManager (real node registry, link/liveness tracking and Dijkstra shortest-path routing with self-healing failover) and the ProtocolBridgeManager (translates any external system's wire format into the unified MeshMessage envelope and relays it across the mesh via real HTTP forwarding).</Summary>
    <Version>1.0.0</Version>
    <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\OASIS Architecture\NextGenSoftware.OASIS.API.Core\NextGenSoftware.OASIS.API.Core.csproj" />
    <ProjectReference Include="..\..\OASIS Architecture\NextGenSoftware.OASIS.OASISBootLoader\NextGenSoftware.OASIS.OASISBootLoader.csproj" />
    <ProjectReference Include="..\..\OASIS Architecture\NextGenSoftware.OASIS.API.DNA\NextGenSoftware.OASIS.API.DNA.csproj" />
    <ProjectReference Include="..\..\ONODE\NextGenSoftware.OASIS.API.ONODE.Core\NextGenSoftware.OASIS.API.ONODE.Core.csproj" />
  </ItemGroup>

</Project>
