  <PropertyGroup>
    <PackageId>NextGenSoftware.OASIS.API.DNA</PackageId>
    <Version>2.0.0</Version>
    <Title>WEB4 OASIS API DNA</Title>
    <Product>WEB4 OASIS API DNA</Product>
    <Summary>OASIS DNA configuration model — strongly-typed binding for OASIS_DNA.json that controls provider selection, failover, load-balancing, replication, encryption and all core OASIS engine settings.</Summary>
    <Description>OASIS DNA configuration model — strongly-typed binding for OASIS_DNA.json that controls provider selection, failover, load-balancing, replication, encryption and all core OASIS engine settings.</Description>
    <Authors>David Ellams (NextGen Software Ltd)</Authors>
    <Company>NextGen Software Ltd</Company>
    <Copyright>Copyright © NextGen Software Ltd 2024</Copyright>
    <PackageTags>OASIS; API; WEB4; WEB5; WEB6; WEB7; WEB8; WEB9; WEB10; STAR; ODK; OAPP; Omniverse; Blockchain; NFT; Tokens; Crypto; Metaverse; Holochain; P2P; Decentralised; Distributed; Interoperability; Abstraction-Layer; Multi-Chain; SSO; Avatar-API; Karma-API; Data-API; FAHRN; HolonicBraid; ONET; HyperDrive; MCP; AI; Future-Proof; NextGenSoftware</PackageTags>
    <PackageProjectUrl>https://github.com/NextGenSoftwareUK/Our-World-OASIS-API-HoloNET-HoloUnity-And-.NET-HDK</PackageProjectUrl>
    <RepositoryUrl>https://github.com/NextGenSoftwareUK/Our-World-OASIS-API-HoloNET-HoloUnity-And-.NET-HDK</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageIcon>OASIS.jpg</PackageIcon>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReleaseNotes>- Initial NuGet release as part of the OASIS Omniverse Reboot and Rebrand under oasisomniverse.one.
- Upgraded to .NET 10 — latest runtime with improved performance and language features.
- Full integration with OASIS API Core v2.0.0, WEB6-WEB10 layers, ONET, FAHRN, HyperDrive v2, and OASIS MCP Server.
- Security-hardened: CORS, JWT, and NuGet vulnerability remediation.
- Many misc improvements.
- Multiple bug fixes.</PackageReleaseNotes>
  </PropertyGroup>
<ItemGroup>
    <None Remove="OASIS_DNA.json" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Default\OASIS_DNA.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="OASIS_DNA.Development.json" Condition="Exists('OASIS_DNA.Development.json')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
    <Content Include="OASIS_DNA.json" Condition="Exists('OASIS_DNA.json')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

	<ItemGroup>
		<None Include="..\..\Logos\OASIS.jpg" Pack="true" PackagePath="\"/>
	</ItemGroup>

	<ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.1" />
  </ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\NextGenSoftware.OASIS.Common\NextGenSoftware.OASIS.Common.csproj" />
	  <ProjectReference Include="..\..\..\NextGenSoftware-Libraries\NextGenSoftware.Utilities\NextGenSoftware.Utilities.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <Reference Include="NextGenSoftware.OASIS.DNALoader">
	    <HintPath>External\NextGenSoftware.OASIS.DNALoader.dll</HintPath>
	  </Reference>
	</ItemGroup>

  <ItemGroup>
    <None Update="README.md">
      <PackagePath>\</PackagePath>
      <Pack>True</Pack>
    </None>
  </ItemGroup>

  <!-- Removed reference to Core to avoid circular dependency with Core referencing DNA. -->

  <!-- Exclude any test files from main DNA library build -->
  <ItemGroup>
    <Compile Remove="**\*.IntegrationTests.cs" />
    <Compile Remove="**\*IntegrationTests.cs" />
    <Compile Remove="**\*UnitTests.cs" />
    <Compile Remove="**\*Tests.cs" />
    <None Include="**\*.IntegrationTests.cs" />
    <None Include="**\*IntegrationTests.cs" />
    <None Include="**\*UnitTests.cs" />
    <None Include="**\*Tests.cs" />
  </ItemGroup>

</Project>
