<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
    <PackageId>NextGenSoftware.OASIS.Web10.Core</PackageId>
    <Company>NextGen Software Ltd</Company>
    <Product>WEB10 OASIS Source Layer Core</Product>
    <Title>WEB10 OASIS Source Layer Core</Title>
    <Description>The Core for WEB10 (The Source / WEB0) - the root source-of-truth layer of the OASIS Omniverse. The SourceManager returns the foundational OASIS_DNA configuration (the Alpha) together with WEB9 live unified status across WEB4-WEB8 (the Omega), closing the loop where WEB10 = WEB0.</Description>
    <Summary>The Core for WEB10 - "The Source" / WEB0, made literal as the single root source-of-truth endpoint for the entire OASIS stack. The SourceManager returns the foundational OASIS_DNA configuration every other layer derives from (the Alpha) together with WEB9's live unified status report across WEB4-WEB8 (the Omega) - closing the loop the site describes ("WEB10 = WEB0") as one real, queryable endpoint instead of metaphor.</Summary>
    <Version>2.0.1</Version>
    <PackageReleaseNotes>- Initial release as part of the OASIS Omniverse Reboot and Rebrand under oasisomniverse.one.
- Part of the new decentralised WEB6-WEB10 API tier architecture (AI, Spatial/AR, Holographic, Neural, Omniversal layers).
- Integrates with ONET, FAHRN, HolonicBraid, and HyperDrive v2 for full mesh routing.
- Security-hardened from day one: CORS open/pluggable policy, JWT middleware, API key support.
- Built on .NET 10 from the ground up for maximum performance and longevity.
- Miscellaneous bug fixes and improvements during initial stabilisation.
- Many misc improvements.
- Multiple bug fixes.</PackageReleaseNotes>
    <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
    <PackageIcon>OASIS.jpg</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\Logos\OASIS.jpg" Pack="true" PackagePath="\"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\OASIS Architecture\NextGenSoftware.OASIS.API.Core\NextGenSoftware.OASIS.API.Core.csproj" />
    <ProjectReference Include="..\..\OASIS Architecture\NextGenSoftware.OASIS.OASISBootLoader\NextGenSoftware.OASIS.OASISBootLoader.csproj" />
    <ProjectReference Include="..\..\OASIS Architecture\NextGenSoftware.OASIS.API.DNA\NextGenSoftware.OASIS.API.DNA.csproj" />
    <ProjectReference Include="..\..\WEB9\NextGenSoftware.OASIS.Web9.Core\NextGenSoftware.OASIS.Web9.Core.csproj" />
  </ItemGroup>

</Project>
