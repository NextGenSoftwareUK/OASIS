<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Library</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <PackageId>NextGenSoftware.OASIS.API.Providers.RadixOASIS</PackageId>
        <Company>NextGen Software Ltd</Company>
        <Product>WEB4 OASIS API Radix OASIS Provider</Product>
        <Title>WEB4 OASIS API Radix OASIS Provider</Title>
        <Summary>Radix OASIS Provider -- asset-centric DeFi blockchain with Cerberus consensus and Radix Engine for safe, predictable OASIS data. https://oasisomniverse.one</Summary>
        <Description>Connects the OASIS to Radix -- asset-centric blockchain built for DeFi with Cerberus BFT consensus, Radix Engine v2, and native asset types that eliminate common smart contract vulnerabilities. Stores OASIS holons, avatars, and resources. Part of the OASIS HOT-Swappable Provider Architecture. Ecosystem: https://oasisomniverse.one</Description>
        <PackageProjectUrl>https://oasisomniverse.one</PackageProjectUrl>
        <Authors>David Ellams (NextGen Software Ltd), Quantum Street Team</Authors>
        <PackageTags>OASIS API; Radix; WEB4; Provider; Bridge; Cross-Chain</PackageTags>
        <PackageReleaseNotes>- OASIS Omniverse Reboot and Rebrand: major ecosystem relaunch under oasisomniverse.one.
- Full implementation of all remaining provider interface stubs — no more NotImplementedExceptions.
- Security hardening: NuGet vulnerability remediation, CORS and JWT alignment.
- Improved error handling: explicit errors when provider returns null content; null guards throughout.
- Updated to align with OASIS API Core v2.0.0.
- Upgraded to .NET 10 — latest runtime with significant performance and GC improvements.
- Miscellaneous bug fixes and stability improvements.
- Improved null safety and error reporting.
- Internal refactoring to align with OASIS API Core v2.0.0 conventions.
- Many misc improvements.
- Multiple bug fixes.</PackageReleaseNotes>
        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/NextGenSoftwareUK/OASIS</RepositoryUrl>
        <Copyright>Copyright © NextGen Software Ltd 2019 - 2026</Copyright>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
        <Version>2.0.1</Version>
        <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
        <PackageIcon>OASIS.jpg</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\..\Logos\OASIS.jpg" Pack="true" PackagePath="\"/>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="RadixDlt.RadixEngineToolkit" Version="2.2.2" />
      <PackageReference Include="NBitcoin" Version="9.0.3" />
      <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\..\OASIS Architecture\NextGenSoftware.OASIS.API.Core\NextGenSoftware.OASIS.API.Core.csproj" />
      <ProjectReference Include="..\..\..\OASIS Architecture\NextGenSoftware.OASIS.Common\NextGenSoftware.OASIS.Common.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Update="README.md">
        <PackagePath>\</PackagePath>
        <Pack>True</Pack>
      </None>
    </ItemGroup>

</Project>

