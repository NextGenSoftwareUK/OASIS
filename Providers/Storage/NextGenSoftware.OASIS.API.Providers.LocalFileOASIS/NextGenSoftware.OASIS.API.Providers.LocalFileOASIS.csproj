<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	  <PackageId>NextGenSoftware.OASIS.API.Providers.LocalFileOASIS</PackageId>
	  <Company>NextGen Software Ltd</Company>
	  <Product>WEB4 OASIS API Local File OASIS Provider</Product>
	  <Title>WEB4 OASIS API Local File OASIS Provider</Title>
	  <Summary>Local File OASIS Provider -- flat-file JSON persistence for OASIS holons and avatars. Ideal for development, offline, IoT edge, and embedded deployments. https://oasisomniverse.one</Summary>
	  <Description>Connects the OASIS to local file system storage -- persists OASIS holons and avatar data as JSON files on disk with zero external dependencies. The simplest provider for development, testing, offline-first apps, IoT edge nodes, or embedded deployments. Part of the OASIS HOT-Swappable Provider Architecture. Ecosystem: https://oasisomniverse.one</Description>
	  <PackageProjectUrl>https://oasisomniverse.one</PackageProjectUrl>
	  <PackageIcon>OASIS.jpg</PackageIcon>
	  <Authors>David Ellams (NextGen Software Ltd)</Authors>
	  <PackageTags>OASIS API; Native; Integrated; WEB4; Provider </PackageTags>
	  <PackageReleaseNotes>- OASIS Omniverse Reboot and Rebrand: major ecosystem relaunch under oasisomniverse.one.
- Full implementation of all remaining provider interface stubs — no more NotImplementedExceptions.
- Security hardening: NuGet vulnerability remediation, CORS and JWT alignment.
- Improved error handling: explicit errors when provider returns null content; null guards throughout.
- Updated to align with OASIS API Core v2.0.0.
- Upgraded to .NET 10 — latest runtime with significant performance and GC improvements.
- Miscellaneous bug fixes and stability improvements.
- Improved null safety and error reporting.
- Internal refactoring to align with OASIS API Core v2.0.0 conventions.
- Many misc improvements.
- Multiple bug fixes.</PackageReleaseNotes>
	  <RepositoryType>git</RepositoryType>
	  <RepositoryUrl>https://github.com/NextGenSoftwareUK/OASIS</RepositoryUrl>
	  <Copyright>Copyright © NextGen Software Ltd 2019 - 2026</Copyright>
	  <PackageReadmeFile>README.md</PackageReadmeFile>
	  <!--<PackageLicenseExpression>GNU GPLv3</PackageLicenseExpression>-->
	  <PackageLicenseExpression>MIT</PackageLicenseExpression>
	  <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
	  <Version>2.0.0</Version>
	  <!--<PackageLicenseFile>..\LICENSE</PackageLicenseFile>-->

	  <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\..\Logos\OASIS.jpg" Link="OASIS.jpg">
      <PackagePath>\</PackagePath>
      <Pack>True</Pack>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\OASIS Architecture\NextGenSoftware.OASIS.API.Core\NextGenSoftware.OASIS.API.Core.csproj" />
    <ProjectReference Include="..\..\..\OASIS Architecture\NextGenSoftware.OASIS.Common\NextGenSoftware.OASIS.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="README.md">
      <PackagePath>\</PackagePath>
      <Pack>True</Pack>
    </None>
  </ItemGroup>

</Project>
