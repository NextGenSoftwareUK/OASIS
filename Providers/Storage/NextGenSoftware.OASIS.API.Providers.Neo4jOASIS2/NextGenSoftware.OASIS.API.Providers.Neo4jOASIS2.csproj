<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  
  <PropertyGroup>
    <PackageId>NextGenSoftware.OASIS.API.Providers.Neo4jOASIS2</PackageId>
    <Version>2.0.0</Version>
    <Title>OASIS Neo4j V2 OASIS Provider</Title>
    <Product>OASIS Neo4j V2 OASIS Provider</Product>
    <Summary>Neo4j V2 OASIS Provider — fully-implemented graph database provider using Neo4j and the Bolt protocol, with rich relationship mapping for holons, avatars, karma, and the social graph.</Summary>
    <Description>Neo4j V2 OASIS Provider — fully-implemented graph database provider using Neo4j and the Bolt protocol, with rich relationship mapping for holons, avatars, karma, and the social graph.</Description>
    <Authors>David Ellams (NextGen Software Ltd)</Authors>
    <Company>NextGen Software Ltd</Company>
    <Copyright>Copyright © NextGen Software Ltd 2024</Copyright>
    <PackageTags>OASIS; API; WEB4; WEB5; WEB6; WEB7; WEB8; WEB9; WEB10; STAR; ODK; OAPP; Omniverse; Blockchain; NFT; Tokens; Crypto; Metaverse; Holochain; P2P; Decentralised; Distributed; Interoperability; Abstraction-Layer; Multi-Chain; SSO; Avatar-API; Karma-API; Data-API; FAHRN; HolonicBraid; ONET; HyperDrive; MCP; AI; Future-Proof; NextGenSoftware</PackageTags>
    <PackageProjectUrl>https://github.com/NextGenSoftwareUK/Our-World-OASIS-API-HoloNET-HoloUnity-And-.NET-HDK</PackageProjectUrl>
    <RepositoryUrl>https://github.com/NextGenSoftwareUK/Our-World-OASIS-API-HoloNET-HoloUnity-And-.NET-HDK</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageIcon>OASIS.jpg</PackageIcon>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReleaseNotes>- Initial NuGet release as part of the OASIS Omniverse Reboot and Rebrand under oasisomniverse.one.
- Full implementation of all provider interface methods — no NotImplementedExceptions.
- Upgraded to .NET 10.
- Updated to align with OASIS API Core v2.0.0.
- Security hardening: NuGet vulnerability fixes, improved null safety.
- Many misc improvements.
- Multiple bug fixes.</PackageReleaseNotes>
  </PropertyGroup>
<ItemGroup>
    <PackageReference Include="Neo4jClient" Version="4.1.18" />
    <PackageReference Include="Neo4jOgm" Version="0.21.8" />
  
    <None Include="..\..\..\Logos\OASIS.jpg" Pack="true" PackagePath="\"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\OASIS Architecture\NextGenSoftware.OASIS.API.Core\NextGenSoftware.OASIS.API.Core.csproj" />
  </ItemGroup>

</Project>
